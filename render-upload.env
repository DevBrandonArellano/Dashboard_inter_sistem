NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1

# Keycloak - URL base del servidor (ej: https://keycloak.tudominio.com)
KEYCLOAK_URL=https://XXXXXXXXXXXXXXXX

# Keycloak - Nombre del realm (por defecto: sebdom-integrador)
KEYCLOAK_REALM=sebdom-integrador

# Keycloak - Client ID del cliente OIDC (por defecto: sistema-b)
KEYCLOAK_CLIENT_ID=sistema-b

# Keycloak - Secret del cliente (Panel Keycloak > Clients > sistema-b > Credentials)
KEYCLOAK_CLIENT_SECRET=XXXXXXXXXXXXXXXX

# Vault - URL del servidor HashiCorp Vault (ej: https://vault.tudominio.com:8200)
VAULT_ADDR=https://XXXXXXXXXXXXXXXX

# Vault - Token de acceso (Panel Vault > Tokens)
VAULT_TOKEN=XXXXXXXXXXXXXXXX

# Vault - Nombre de la llave Transit (por defecto: sebdom-interop-key)
VAULT_TRANSIT_KEY=sebdom-interop-key

# Vault - Namespace (por defecto: admin)
VAULT_NAMESPACE=admin
